<Window x:Class="Ojaswat.Windows.QuickEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit" SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <StackPanel Margin="20,16,20,16" x:Name="FieldsPanel">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" IsDefault="True" Click="Save_Click"
                    Background="#3B82F6" Foreground="White" Width="80" Height="34"
                    BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True"
                    Background="#F1F5F9" Foreground="#475569" Width="80" Height="34"
                    BorderThickness="0" FontSize="13" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
