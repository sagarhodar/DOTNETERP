<Window x:Class="Ojaswat.Windows.TandCEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="T&amp;C Template" Height="440" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8F9FC" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/><RowDefinition Height="*"/><RowDefinition Height="58"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#1E293B" Padding="20,0">
            <TextBlock x:Name="TitleText" Text="New T&amp;C Template" Foreground="White"
                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Row="1" Margin="22,18,22,8">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Label / Name" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="LabelBox" Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Applicable Doc Type" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="DocTypeCombo" Height="36" FontSize="13">
                        <ComboBoxItem Content="All"             IsSelected="True"/>
                        <ComboBoxItem Content="Quotation"/>
                        <ComboBoxItem Content="SalesOrder"/>
                        <ComboBoxItem Content="SalesInvoice"/>
                        <ComboBoxItem Content="CreditNote"/>
                        <ComboBoxItem Content="PurchaseOrder"/>
                        <ComboBoxItem Content="PurchaseInvoice"/>
                        <ComboBoxItem Content="GRN"/>
                        <ComboBoxItem Content="DebitNote"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="Payment Terms" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="PaymentBox" Height="38" Padding="10,0" FontSize="12" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="General Terms &amp; Conditions" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="GeneralBox" Height="100" Padding="10,8" FontSize="12"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </StackPanel>
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,18,0">
                <Button Content="Cancel" Click="Cancel_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Width="90" Height="38" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="💾  Save Template" Click="Save_Click"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Width="150" Height="38" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
