<Window x:Class="Ojaswat.Windows.StockAdjustmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manual Stock Adjustment" Height="380" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8F9FC" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="58"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E293B" Padding="20,0">
            <TextBlock Text="📦  Manual Stock Adjustment" Foreground="White"
                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,18,24,8">
            <TextBlock Text="Item" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="ItemCombo" Height="38" FontSize="13"
                      SelectionChanged="ItemCombo_Changed"/>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Adjustment Type" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="TypeCombo" Height="38" FontSize="13">
                        <ComboBoxItem Content="ADJUST_IN  (Add stock)"    Tag="ADJUST_IN"  IsSelected="True"/>
                        <ComboBoxItem Content="ADJUST_OUT (Remove stock)" Tag="ADJUST_OUT"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Quantity" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="QtyBox" Height="38" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center" Text="1"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/><ColumnDefinition Width="16"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="UOM" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="UOMBox" Height="38" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Current Stock (read-only)" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="CurrentStockBox" Height="38" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center" IsReadOnly="True" Background="#F1F5F9"/>
                </StackPanel>
            </Grid>

            <StackPanel Margin="0,12,0,0">
                <TextBlock Text="Narration / Reason" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="NarrationBox" Height="50" Padding="10,8" FontSize="13"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <TextBlock x:Name="ErrText" Foreground="#EF4444" FontSize="11"
                       Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Content="Cancel" Click="Cancel_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Width="100" Height="38" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="✔  Post Adjustment" Click="Save_Click"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Width="180" Height="38" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
