<Window x:Class="Ojaswat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ojaswat"
        xmlns:pages="clr-namespace:Ojaswat.Pages"
        Title="{Binding Source={x:Static local:App.Version}, StringFormat=OJASWAT ERP v{0}}"
        Height="860" Width="1400" MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#F1F5F9" FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <local:PageTemplateSelector x:Key="PageTemplateSelector"/>

        <!-- Existing pages -->
        <DataTemplate x:Key="DT_dash">        <pages:DashboardPage/>    </DataTemplate>
        <DataTemplate x:Key="DT_finance">     <pages:FinancePage/>      </DataTemplate>
        <DataTemplate x:Key="DT_gst">         <pages:GstReportPage/>    </DataTemplate>
        <DataTemplate x:Key="DT_config">      <pages:ConfigPage/>       </DataTemplate>
        <DataTemplate x:Key="DT_master">      <pages:MasterDataPage/>   </DataTemplate>
        <DataTemplate x:Key="DT_tandc">       <pages:TandCPage/>        </DataTemplate>
        <DataTemplate x:Key="DT_items">       <pages:ReportItemsPage/>  </DataTemplate>
        <DataTemplate x:Key="DT_help">        <pages:HelpPage/>         </DataTemplate>
        <!-- NEW -->
        <DataTemplate x:Key="DT_inventory">   <pages:InventoryPage/>    </DataTemplate>
        <DataTemplate x:Key="DT_ledger">      <pages:LedgerPage/>       </DataTemplate>
        <!-- Document list variants -->
        <DataTemplate x:Key="DT_doclist">     <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_sales">       <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_purchase">    <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_quotation">   <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_salesorder">  <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_salesinvoice"><pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_creditnote">  <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_purchaseorder">   <pages:DocumentListPage/></DataTemplate>
        <DataTemplate x:Key="DT_purchaseinvoice"> <pages:DocumentListPage/></DataTemplate>
        <DataTemplate x:Key="DT_grn">         <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_debitnote">   <pages:DocumentListPage/> </DataTemplate>
        <DataTemplate x:Key="DT_pending">     <pages:DocumentListPage/> </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SIDEBAR ─────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#0F172A">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="14,18,14,12">
                    <Grid>
                        <Image x:Name="SidebarLogo" MaxHeight="48" MaxWidth="160"
                               Stretch="Uniform" HorizontalAlignment="Left"
                               Margin="0,0,0,6" Visibility="Collapsed"/>
                        <StackPanel x:Name="SidebarBrand" Visibility="Visible">
                            <TextBlock Text="◈ Ojaswat" Foreground="#60A5FA"
                                       FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="Professional ERP  v13" Foreground="#334155"
                                       FontSize="9.5" Margin="2,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="🖼  Set Logo"
                            Background="Transparent" Foreground="#64748B"
                            BorderThickness="0" Cursor="Hand" Height="22" FontSize="10"
                            HorizontalAlignment="Left" Padding="4,0" Click="SetLogo_Click"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1E293B" Margin="10,0"/>

                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="OVERVIEW" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  ⬡  Dashboard"
                                     Style="{StaticResource NavRadioBtn}" IsChecked="True"
                                     Command="{Binding NavDashboardCommand}"/>

                        <TextBlock Text="SALES" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  ▤  All Sales Docs"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavSalesAllCommand}"/>
                        <RadioButton Content="     Quotations"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavQuotationCommand}"/>
                        <RadioButton Content="     Sales Orders"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavSalesOrderCommand}"/>
                        <RadioButton Content="     Sales Invoices"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavSalesInvoiceCommand}"/>
                        <RadioButton Content="     Credit Notes"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavCreditNoteCommand}"/>

                        <TextBlock Text="PURCHASE" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  ▤  All Purchase Docs"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavPurchaseAllCommand}"/>
                        <RadioButton Content="     Purchase Orders"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavPurchaseOrderCommand}"/>
                        <RadioButton Content="     Purchase Invoices"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavPurchaseInvoiceCommand}"/>
                        <RadioButton Content="     GRN"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavGRNCommand}"/>
                        <RadioButton Content="     Debit Notes"
                                     Style="{StaticResource SubNavRadioBtn}"
                                     Command="{Binding NavDebitNoteCommand}"/>

                        <TextBlock Text="FINANCE" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  ₹  Payment Ledger"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavFinanceCommand}"/>
                        <RadioButton Content="  📊  GST Report"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavGstReportCommand}"/>

                        <!-- ══ NEW: INVENTORY + LEDGER ══ -->
                        <TextBlock Text="INVENTORY &amp; LEDGER" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  📦  Inventory"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavInventoryCommand}"/>
                        <RadioButton Content="  📒  Party Ledger"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavLedgerCommand}"/>

                        <TextBlock Text="REPORTS" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  📄  All Documents"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavReportAllCommand}"/>
                        <RadioButton Content="  ⏳  Pending / Open"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavReportPendingCommand}"/>
                        <RadioButton Content="  📦  Docs with Items"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavReportItemsCommand}"/>

                        <TextBlock Text="CONFIG" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  ⚙  Company &amp; Settings"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavConfigCommand}"/>
                        <RadioButton Content="  ⇄  Master Data / CSV"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavMasterDataCommand}"/>
                        <RadioButton Content="  📋  T&amp;C Master"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavTandCCommand}"/>

                        <Button Content="  ⇪  Export DB"
                                Background="Transparent" Foreground="#94A3B8"
                                BorderThickness="0" Cursor="Hand" Height="36"
                                FontSize="12" FontFamily="Segoe UI"
                                HorizontalContentAlignment="Left" Padding="14,0"
                                Margin="6,1" Click="Nav_ExportDb"/>
                        <Button Content="  ⇩  Import DB"
                                Background="Transparent" Foreground="#94A3B8"
                                BorderThickness="0" Cursor="Hand" Height="36"
                                FontSize="12" FontFamily="Segoe UI"
                                HorizontalContentAlignment="Left" Padding="14,0"
                                Margin="6,1" Click="Nav_ImportDb"/>

                        <TextBlock Text="HELP" Style="{StaticResource ModuleLabel}"/>
                        <RadioButton Content="  ❓  Help &amp; About"
                                     Style="{StaticResource NavRadioBtn}"
                                     Command="{Binding NavHelpCommand}"/>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock DockPanel.Dock="Bottom" Text="v13 · DuckDB · MVVM"
                           Foreground="#1E293B" FontSize="9"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
            </DockPanel>
        </Border>

        <!-- ── MAIN AREA ───────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Border VerticalAlignment="Top" Height="52" Background="#FFFFFF"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Panel.ZIndex="10">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding PageTitle}"
                               Foreground="#0F172A" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                               Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ContentControl Margin="0,52,0,0"
                            Content="{Binding CurrentPageKey}"
                            ContentTemplateSelector="{StaticResource PageTemplateSelector}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
