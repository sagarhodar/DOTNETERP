### FILE: Pages\FinancePage.xaml
################################################################################

```xaml
<UserControl x:Class="Ojaswat.Pages.FinancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,12"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="✚  New Payment" Click="NewPayment_Click"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Height="34" Padding="14,0" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Content="⬇  Export CSV" Click="ExportPayments_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Height="34" Padding="14,0" Margin="8,0,0,0" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Content="⟳" Click="Refresh_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Height="34" Width="34" Margin="8,0,0,0" Cursor="Hand"/>
                <TextBlock x:Name="StatusText" Foreground="#64748B" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="18,14,18,18" Background="#FFFFFF"
                CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="PaymentGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Document No" Binding="{Binding DocumentNo}" Width="140"/>
                    <DataGridTextColumn Header="Party"       Binding="{Binding PartyName}"  Width="*"/>
                    <DataGridTextColumn Header="Date"        Binding="{Binding DateLabel}"  Width="105"/>
                    <DataGridTextColumn Header="Amount"      Binding="{Binding Amount, StringFormat='₹{0:N2}'}" Width="110"/>
                    <DataGridTextColumn Header="Mode"        Binding="{Binding ModeLabel}"  Width="85"/>
                    <DataGridTextColumn Header="Reference"   Binding="{Binding Reference}"  Width="130"/>
                    <DataGridTextColumn Header="Notes"       Binding="{Binding Notes}"       Width="*"/>
                    <DataGridTemplateColumn Header="" Width="36">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑" Tag="{Binding}" Background="Transparent"
                                        BorderThickness="0" FontSize="13" Cursor="Hand"
                                        Click="PaymentDelete_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

