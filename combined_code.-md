################################################################################
### FILE: Renderers\PurchaseOrderRenderer.cs
################################################################################

```cs
using System;
using System.IO;
using System.Linq;
using Ojaswat.Models;
using QuestPDF.Fluent;
using QuestPDF.Helpers;
using QuestPDF.Infrastructure;

namespace Ojaswat.Renderers;

/// <summary>
/// Completely custom layout for Purchase Order.
/// Bypasses the shared RendererBase layout.
/// </summary>
public sealed class PurchaseOrderRenderer : DefaultRenderer
{
    public override IDocument BuildPdf(ErpDocument doc)
    {
        return Document.Create(container =>
        {
            container.Page(page =>
            {
                page.Size(PageSizes.A4);
                page.Margin(10, Unit.Millimetre);
                page.PageColor(Colors.White);
                page.DefaultTextStyle(x => x.FontSize(10).FontFamily(Fonts.Arial).FontColor(Colors.Black));

                // 1. REPEATING HEADER
                page.Header().Element(c => ComposePOHeader(c, doc));

                // 2. MAIN CONTENT
                page.Content().PaddingTop(6).Column(col =>
                {
                    col.Item().Element(c => ComposePOItemsTable(c, doc));
                    col.Item().Element(c => ComposePOTotalsAndTerms(c, doc));
                    
                    // Purchase orders usually don't need your bank details, 
                    // but you can uncomment this if you want them back.
                    // col.Item().Element(c => ComposePOBankSection(c, doc));
                    
                    col.Item().Element(c => ComposePOSignatory(c, doc));
                });
                
                // 3. FOOTER
                page.Footer().PaddingTop(5).Row(row => {
                    row.RelativeItem().Text($"Generated: {DateTime.Now:dd MMM yyyy HH:mm}").FontSize(8).FontColor(Colors.Grey.Medium);
                    row.RelativeItem().AlignCenter().Text($"PURCHASE ORDER · {CleanDocNo(doc.DocumentNo)}").FontSize(8).Bold();
                    row.RelativeItem().AlignRight().Text(text => {
                        text.Span("Page ").FontSize(8).FontColor(Colors.Grey.Medium);
                        text.CurrentPageNumber().FontSize(8).FontColor(Colors.Grey.Medium);
                    });
                });
            });
        });
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CUSTOM PURCHASE ORDER SECTIONS (Tweak anything below!)
    // ══════════════════════════════════════════════════════════════════════════

    private void ComposePOHeader(IContainer container, ErpDocument doc)
    {
        container.Column(col =>
        {
            col.Item().PaddingBottom(8).Row(row =>
            {
                row.RelativeItem().Column(c =>
                {
                    c.Item().Text(doc.Company.Name).FontSize(18).Bold();
                    c.Item().Text(doc.Company.Address).FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Company.Email)) c.Item().Text($"Email: {doc.Company.Email}").FontSize(10);
                    c.Item().Text($"GSTIN: {doc.Company.GSTIN}").FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Company.StateCode)) c.Item().Text($"State: {doc.Company.StateCode}").FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Company.Phone)) c.Item().Text($"Ph: {doc.Company.Phone}").FontSize(10);
                });

                if (!string.IsNullOrEmpty(doc.Company.LogoPath) && File.Exists(doc.Company.LogoPath))
                {
                    try {
                        byte[] logoBytes = File.ReadAllBytes(doc.Company.LogoPath);
                        row.ConstantItem(150).AlignRight().Height(55).Image(logoBytes).FitArea();
                    } catch { }
                }
            });

            col.Item().BorderTop(1).BorderBottom(1).BorderColor(Colors.Black)
               .PaddingVertical(4).AlignCenter().Text("PURCHASE ORDER").FontSize(12).Bold();

            col.Item().PaddingVertical(8).Row(row =>
            {
                // VENDOR (Left)
                row.RelativeItem().PaddingRight(10).Column(c =>
                {
                    c.Item().Text("VENDOR").FontSize(8).Bold().FontColor(Colors.Grey.Medium);
                    c.Item().Text(doc.Customer.Name).FontSize(11).Bold();
                    c.Item().Text(doc.Customer.BillingAddress).FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Customer.GSTIN)) c.Item().Text($"GSTIN: {doc.Customer.GSTIN}").FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Customer.StateCode)) c.Item().Text($"State: {doc.Customer.StateCode}").FontSize(10);
                });

                // DELIVER TO (Middle)
                row.RelativeItem().BorderLeft(1).BorderColor(Colors.Grey.Lighten2).PaddingLeft(10).PaddingRight(10).Column(c =>
                {
                    c.Item().Text("DELIVER TO").FontSize(8).Bold().FontColor(Colors.Grey.Medium);
                    string shipAddr = string.IsNullOrWhiteSpace(doc.Customer.ShippingAddress) ? doc.Customer.BillingAddress : doc.Customer.ShippingAddress;
                    c.Item().Text(shipAddr).FontSize(10);
                });

                // DETAILS (Right)
                row.RelativeItem().BorderLeft(1).BorderColor(Colors.Grey.Lighten2).PaddingLeft(10).Column(c =>
                {
                    c.Item().PaddingBottom(4).Text("ORDER DETAILS").FontSize(8).Bold().FontColor(Colors.Grey.Medium);
                    void AddRow(string lbl, string val) {
                        c.Item().Row(r => { r.RelativeItem().Text(lbl).FontSize(10); r.RelativeItem().AlignRight().Text(val).FontSize(10).Bold(); });
                    }
                    AddRow("PO No. :", CleanDocNo(doc.DocumentNo));
                    AddRow("Date :", doc.Date.ToString("dd-MM-yyyy"));
                    if (!string.IsNullOrEmpty(doc.PlaceOfSupply)) AddRow("Place of supply:", doc.PlaceOfSupply);
                    if (!string.IsNullOrEmpty(doc.CreatedBy)) AddRow("Prepared by:", doc.CreatedBy);
                });
            });
            col.Item().LineHorizontal(1).LineColor(Colors.Black);
        });
    }

    private void ComposePOItemsTable(IContainer container, ErpDocument doc)
    {
        container.Table(table =>
        {
            table.ColumnsDefinition(columns =>
            {
                columns.ConstantColumn(25);   // #
                columns.RelativeColumn();     // Description
                columns.ConstantColumn(60);   // HSN
                columns.ConstantColumn(45);   // Qty
                columns.ConstantColumn(35);   // Unit
                columns.ConstantColumn(65);   // Rate
                columns.ConstantColumn(55);   // GST
                columns.ConstantColumn(80);   // Amount
            });

            table.Header(header =>
            {
                void HeadCell(IContainer c, string text, bool right = false) {
                    var cell = c.BorderBottom(1).BorderColor(Colors.Black).PaddingVertical(4).PaddingHorizontal(3);
                    if (right) cell.AlignRight().Text(text).FontSize(9).Bold(); else cell.Text(text).FontSize(9).Bold();
                }
                HeadCell(header.Cell(), "#");
                HeadCell(header.Cell(), "Item Name");
                HeadCell(header.Cell(), "HSN/SAC");
                HeadCell(header.Cell(), "Qty", true);
                HeadCell(header.Cell(), "Unit", true);
                HeadCell(header.Cell(), "Rate", true);
                HeadCell(header.Cell(), "GST", true);
                HeadCell(header.Cell(), "Amount", true);
            });

            foreach (var item in doc.Items)
            {
                decimal gstAmt = item.LineTotal * item.GSTPercent / 100;
                void BodyCell(IContainer c, string text, int size, bool bold = false, bool right = false, string color = "#000000") {
                    var cell = c.BorderBottom(1).BorderColor(Colors.Grey.Lighten3).PaddingVertical(4).PaddingHorizontal(3);
                    var txt = right ? cell.AlignRight().Text(text) : cell.Text(text);
                    txt.FontSize(size).FontColor(color); if (bold) txt.Bold();
                }
                BodyCell(table.Cell(), item.ItemNumber.ToString(), 9);
                BodyCell(table.Cell(), item.Description, 10, true);
                BodyCell(table.Cell(), item.HSN, 9);
                BodyCell(table.Cell(), item.Quantity.ToString("N2"), 10, false, true);
                BodyCell(table.Cell(), item.UOM, 9, false, true);
                BodyCell(table.Cell(), $"₹{item.Rate:N2}", 10, false, true);
                BodyCell(table.Cell(), $"₹{gstAmt:N2}", 8, false, true, Colors.Grey.Darken2);
                BodyCell(table.Cell(), $"₹{item.LineTotal:N2}", 10, true, true);
            }

            decimal sub = doc.Items.Sum(i => i.LineTotal);
            decimal totalGst = doc.Items.Sum(i => i.LineTotal * i.GSTPercent / 100);

            table.Cell().ColumnSpan(3).PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text("Total").FontSize(10).Bold();
            table.Cell().PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text(doc.Items.Sum(i => i.Quantity).ToString("N2")).FontSize(10).Bold();
            table.Cell().ColumnSpan(2).PaddingVertical(4).PaddingHorizontal(3);
            table.Cell().PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text($"₹{totalGst:N2}").FontSize(9).Bold();
            table.Cell().PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text($"₹{sub:N2}").FontSize(10).Bold();
        });
    }

    private void ComposePOTotalsAndTerms(IContainer container, ErpDocument doc)
    {
        decimal sub = doc.Items.Sum(i => i.LineTotal);
        decimal taxable = sub - doc.Discount;
        decimal tax = taxable * doc.GstPercent / 100;
        decimal grand = taxable + tax + doc.Freight;
        bool isCgst = doc.GstMode == GstMode.CgstSgst;

        container.BorderBottom(1).BorderColor(Colors.Black).Row(row =>
        {
            row.RelativeItem().Padding(10).BorderRight(1).BorderColor(Colors.Grey.Lighten2).Column(c =>
            {
                c.Item().Text("AMOUNT IN WORDS").FontSize(8).Bold();
                c.Item().PaddingBottom(8).Text(AmountInWords(grand)).FontSize(10).Italic();

                if (!string.IsNullOrWhiteSpace(doc.GeneralTerms) || !string.IsNullOrWhiteSpace(doc.PaymentTerms))
                {
                    c.Item().PaddingTop(8).BorderTop(1).BorderColor(Colors.Grey.Lighten3).PaddingTop(4)
                     .Text("TERMS & CONDITIONS").FontSize(8).Bold();
                    int lineNo = 1;
                    if (!string.IsNullOrWhiteSpace(doc.GeneralTerms))
                        foreach (var line in doc.GeneralTerms.Split('\n'))
                            if (!string.IsNullOrWhiteSpace(line)) c.Item().Text($"{lineNo++}. {line.Trim()}").FontSize(9);
                    if (!string.IsNullOrWhiteSpace(doc.PaymentTerms))
                        c.Item().Text($"{lineNo}. {doc.PaymentTerms}").FontSize(9);
                }
            });

            row.ConstantItem(220).Padding(10).Column(c =>
            {
                void AddTot(string lbl, string val, bool isGrand = false) {
                    c.Item().PaddingBottom(4).Row(r => {
                        var txtLbl = r.RelativeItem().Text(lbl).FontSize(isGrand ? 11 : 10); if (isGrand) txtLbl.Bold();
                        var txtVal = r.RelativeItem().AlignRight().Text(val).FontSize(isGrand ? 13 : 10); if (isGrand) txtVal.Bold();
                    });
                }

                AddTot("Sub Total", $"₹{sub:N2}");
                if (doc.Discount > 0) AddTot("Discount", $"-₹{doc.Discount:N2}");
                
                if (isCgst) {
                    AddTot($"CGST @ {doc.GstPercent / 2:N1}%", $"₹{tax / 2:N2}");
                    AddTot($"SGST @ {doc.GstPercent / 2:N1}%", $"₹{tax / 2:N2}");
                } else { AddTot($"IGST @ {doc.GstPercent:N0}%", $"₹{tax:N2}"); }
                
                if (doc.Freight > 0) AddTot("Freight", $"₹{doc.Freight:N2}");

                c.Item().PaddingVertical(4).LineHorizontal(1).LineColor(Colors.Black);
                AddTot("Order Total", $"₹{grand:N2}", true);
            });
        });
    }

    private void ComposePOSignatory(IContainer container, ErpDocument doc)
    {
        container.Padding(15).Row(row =>
        {
            row.RelativeItem(); // Spacer
            row.ConstantItem(180).AlignRight().Column(c =>
            {
                c.Item().Height(50).Border(1).BorderColor(Colors.Grey.Lighten2).AlignCenter().AlignMiddle()
                 .Text("Authorized Signature").FontSize(9).FontColor(Colors.Grey.Lighten1);
                c.Item().PaddingTop(4).BorderTop(1).BorderColor(Colors.Black).PaddingTop(2)
                 .Text($"For: {doc.Company.Name}").FontSize(10).Bold();
            });
        });
    }
}
