```xaml
<UserControl x:Class="Ojaswat.Pages.InventoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,12"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="⟳  Refresh"    Click="Refresh_Click"
                            Style="{StaticResource BtnGhost}" Padding="14,0" Height="34" Margin="0,0,8,0"/>
                    <Button Content="＋  Adjust Stock" Click="Adjust_Click"
                            Style="{StaticResource BtnPrimary}" Padding="14,0" Height="34" Margin="0,0,8,0"/>
                    <Button Content="⬇  Export CSV"  Click="ExportCsv_Click"
                            Style="{StaticResource BtnGreen}" Padding="14,0" Height="34" Margin="0,0,16,0"/>
                    <!-- Item filter -->
                    <TextBlock Text="Filter item:" Foreground="#64748B" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ItemFilterCombo" Width="220" Height="34"
                              SelectionChanged="ItemFilter_Changed"/>
                    <Button Content="✕" Click="ClearFilter_Click"
                            Background="Transparent" Foreground="#94A3B8"
                            BorderThickness="0" Cursor="Hand" Width="28" Height="34"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="StatusText"
                           Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tab layout: Summary | Ledger -->
        <Grid Grid.Row="1" Margin="18,14,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab bar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="TabSummary" Content="  📦  Stock Summary"
                             IsChecked="True" Checked="Tab_Changed"
                             Style="{StaticResource NavRadioBtn}"
                             GroupName="InvTab"
                             Background="#FFFFFF" Foreground="#0F172A"
                             BorderBrush="#E2E8F0" BorderThickness="1"
                             Padding="14,8" Height="36" FontSize="12" Cursor="Hand"/>
                <RadioButton x:Name="TabLedger" Content="  📋  Stock Ledger (All movements)"
                             Checked="Tab_Changed"
                             Style="{StaticResource NavRadioBtn}"
                             GroupName="InvTab"
                             Background="#FFFFFF" Foreground="#0F172A"
                             BorderBrush="#E2E8F0" BorderThickness="1"
                             Padding="14,8" Height="36" FontSize="12" Cursor="Hand"
                             Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Stock Summary grid -->
            <Border x:Name="SummaryPanel" Grid.Row="1"
                    Background="#FFFFFF" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
                <DataGrid x:Name="SummaryGrid" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item Name"     Binding="{Binding ItemName}"     Width="*"/>
                        <DataGridTextColumn Header="HSN"           Binding="{Binding HSN}"          Width="90"/>
                        <DataGridTextColumn Header="UOM"           Binding="{Binding UOM}"          Width="65"/>
                        <DataGridTextColumn Header="Opening Stock" Binding="{Binding OpeningStock, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Total IN"      Binding="{Binding TotalIn, StringFormat='{}{0:N2}'}"      Width="95"/>
                        <DataGridTextColumn Header="Total OUT"     Binding="{Binding TotalOut, StringFormat='{}{0:N2}'}"     Width="95"/>
                        <DataGridTextColumn Header="Current Stock" Binding="{Binding CurrentStock, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Reorder"       Binding="{Binding ReorderLevel, StringFormat='{}{0:N2}'}" Width="80"/>
                        <DataGridTemplateColumn Header="Status" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StockColor}" CornerRadius="4"
                                            Padding="8,2" HorizontalAlignment="Center" Margin="0,5">
                                        <TextBlock Text="{Binding StockStatus}"
                                                   Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Stock Ledger grid -->
            <Border x:Name="LedgerPanel" Grid.Row="1" Visibility="Collapsed"
                    Background="#FFFFFF" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
                <DataGrid x:Name="LedgerGrid" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"       Binding="{Binding DateLabel}"    Width="100"/>
                        <DataGridTextColumn Header="Item"       Binding="{Binding ItemName}"     Width="*"/>
                        <DataGridTextColumn Header="HSN"        Binding="{Binding HSN}"          Width="80"/>
                        <DataGridTextColumn Header="UOM"        Binding="{Binding UOM}"          Width="60"/>
                        <DataGridTemplateColumn Header="Type" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding MovementColor}" CornerRadius="4"
                                            Padding="6,2" HorizontalAlignment="Center" Margin="0,5">
                                        <TextBlock Text="{Binding MovementLabel}"
                                                   Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Qty"        Binding="{Binding Quantity, StringFormat='{}{0:N2}'}"    Width="80"/>
                        <DataGridTextColumn Header="Rate"       Binding="{Binding Rate, StringFormat='₹{0:N2}'}"        Width="90"/>
                        <DataGridTextColumn Header="Value"      Binding="{Binding Value, StringFormat='₹{0:N2}'}"       Width="100"/>
                        <DataGridTextColumn Header="Document"   Binding="{Binding DocumentNo}"   Width="130"/>
                        <DataGridTextColumn Header="Party"      Binding="{Binding PartyName}"    Width="130"/>
                        <DataGridTextColumn Header="Narration"  Binding="{Binding Narration}"    Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

