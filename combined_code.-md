<UserControl x:Class="Ojaswat.Pages.DocumentListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,12"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <!-- Search -->
                    <Border Background="#F8F9FC" BorderBrush="#E2E8F0"
                            BorderThickness="1.5" CornerRadius="7" Width="260" Height="34">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" Margin="9,0,5,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#0F172A" FontSize="12"
                                     VerticalContentAlignment="Center"
                                     TextChanged="Search_Changed"/>
                            <Button x:Name="ClearSearchBtn" Grid.Column="2" Content="✕"
                                    Foreground="#94A3B8" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" Width="28"
                                    Visibility="Collapsed" Click="ClearSearch_Click"/>
                        </Grid>
                    </Border>

                    <!-- Type filter -->
                    <ComboBox x:Name="DocTypeFilterCombo" Width="155" Margin="8,0,0,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Types" IsSelected="True"/>
                        <ComboBoxItem Content="Quotation"/>
                        <ComboBoxItem Content="SalesOrder"/>
                        <ComboBoxItem Content="SalesInvoice"/>
                        <ComboBoxItem Content="CreditNote"/>
                        <ComboBoxItem Content="PurchaseOrder"/>
                        <ComboBoxItem Content="PurchaseInvoice"/>
                        <ComboBoxItem Content="GRN"/>
                        <ComboBoxItem Content="DebitNote"/>
                    </ComboBox>

                    <!-- Status filter -->
                    <ComboBox x:Name="StatusFilterCombo" Width="130" Margin="8,0,0,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Status" IsSelected="True"/>
                        <ComboBoxItem Content="Open"/>
                        <ComboBoxItem Content="Pending"/>
                        <ComboBoxItem Content="Complete"/>
                        <ComboBoxItem Content="Canceled"/>
                    </ComboBox>

                    <Button Content="⟳" Style="{StaticResource BtnGhost}"
                            Margin="8,0,0,0" Width="34" Click="Refresh_Click"/>

                    <TextBlock x:Name="CountText" Foreground="#94A3B8" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <Button x:Name="NewBtn" Grid.Column="1" Content="✚  New"
                        Style="{StaticResource BtnPrimary}" Click="New_Click"/>
            </Grid>
        </Border>

        <!-- Document grid -->
        <Border Grid.Row="1" Margin="18,14,18,18" Background="#FFFFFF"
                CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="DocListGrid"
                      IsReadOnly="True"
                      MouseDoubleClick="DocGrid_DoubleClick"
                      KeyDown="DocGrid_KeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Document No"  Binding="{Binding DocumentNo}"  Width="145"/>
                    <DataGridTextColumn Header="Type"         Binding="{Binding DocTypeLabel}" Width="125"/>
                    <DataGridTextColumn Header="Party"        Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="Ref/PO"       Binding="{Binding CustomerRefNo}" Width="110"/>
                    <DataGridTextColumn Header="Date"         Binding="{Binding DateLabel}"    Width="100"/>
                    <DataGridTextColumn Header="Pending"      Binding="{Binding PendingAmount, StringFormat='₹{0:N2}'}" Width="95"/>
                    <DataGridTextColumn Header="Total"        Binding="{Binding GrandTotal, StringFormat='₹{0:N2}'}" Width="110"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding StatusColor}" CornerRadius="4"
                                        Padding="8,2" HorizontalAlignment="Center" Margin="0,5">
                                    <TextBlock Text="{Binding StatusLabel}"
                                               Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="165">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" Tag="{Binding}" Background="Transparent"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Width="28" Click="DocEdit_Click" ToolTip="Edit"/>
                                    <Button Content="📄" Tag="{Binding}" Background="Transparent"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Width="28" Click="DocPdf_Click" ToolTip="PDF"/>
                                    <Button Content="🌐" Tag="{Binding}" Background="Transparent"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Width="28" Click="DocHtml_Click" ToolTip="HTML"/>
                                    <Button Content="💳" Tag="{Binding}" Background="Transparent"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Width="28" Click="DocAddPayment_Click" ToolTip="Payment"/>
                                    <Button Content="🗑" Tag="{Binding}" Background="Transparent"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Width="28" Click="DocDelete_Click" ToolTip="Delete"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

