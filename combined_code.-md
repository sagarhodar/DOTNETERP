                    <DataGridTextColumn Header="Total Tax"   Binding="{Binding TotalTax, StringFormat='₹{0:N2}'}"   Width="110"/>
                    <DataGridTextColumn Header="Grand Total" Binding="{Binding GrandTotal, StringFormat='₹{0:N2}'}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

