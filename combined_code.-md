using Ojaswat.Models;

namespace Ojaswat.Renderers;

/// <summary>
/// Sales Order — no E-Way Bill, no bank section.
/// Title changes to "Sales Order" (already set by DocLabel).
/// </summary>
public sealed class SalesOrderRenderer : DefaultRenderer
{
    protected override string BuildBankSection(ErpDocument doc) => string.Empty;

    protected override string BuildHeaderGrid(ErpDocument doc)
    {
        string grid = base.BuildHeaderGrid(doc);
        return grid.Replace("<!-- EWAYBILL_PLACEHOLDER -->", "");
    }
}

