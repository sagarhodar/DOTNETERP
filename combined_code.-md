```cs
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Text;
using Ojaswat.Models;
using QuestPDF.Fluent;
using QuestPDF.Helpers;
using QuestPDF.Infrastructure;

namespace Ojaswat.Renderers;

public abstract class RendererBase : IDocRenderer
{
    public abstract IDocument BuildPdf(ErpDocument doc);

    // ── Shared Config Properties (Subclasses override these!) ────────────────
    protected virtual string BillToLabel     => "Bill To";
    protected virtual string ShipToLabel     => "Ship To";
    protected virtual string DocumentNoLabel => "Invoice No. :";
    protected virtual string TotalsLabel     => "Total";
    protected virtual bool   ShowEWayBill    => false;
    protected virtual bool   ShowBankSection => true;

    // ── Colour shortcuts ──────────────────────────────────────────────────────
    protected static string CA   => InvoiceSettings.ColorAccent;
    protected static string CTD  => InvoiceSettings.ColorTextDark;
    protected static string CBR  => InvoiceSettings.ColorBorder;
    protected static string CTH1 => InvoiceSettings.ColorTableHdr1;
    protected static string CTH2 => InvoiceSettings.ColorTableHdr2;
    protected static int    FsS  => InvoiceSettings.FontSizeSmall;
    protected static int    FsM  => InvoiceSettings.FontSizeMeta;

    // ── Static helpers shared by all renderers ────────────────────────────────
    protected static string H(string s) =>
        s.Replace("&", "&amp;").Replace("<", "&lt;")
         .Replace(">", "&gt;").Replace("\"", "&quot;");

    protected static string CleanDocNo(string docNo)
    {
        if (string.IsNullOrWhiteSpace(docNo)) return docNo;
        int idx = docNo.IndexOf("-Rev", StringComparison.OrdinalIgnoreCase);
        return idx > 0 ? docNo[..idx] : docNo;
    }

    protected static string DocLabel(DocumentType t) => t switch
    {
        DocumentType.SalesInvoice    => "Tax Invoice",
        DocumentType.Quotation       => "Quotation",
        DocumentType.SalesOrder      => "Sales Order",
        DocumentType.PurchaseOrder   => "Purchase Order",
        DocumentType.PurchaseInvoice => "Purchase Invoice",
        DocumentType.CreditNote      => "Credit Note",
        DocumentType.DebitNote       => "Debit Note",
        DocumentType.GRN             => "Goods Receipt Note",
        _                            => t.ToString(),
    };

    protected static string AmountInWords(decimal amount)
    {
        try
        {
            long r = (long)Math.Floor(amount);
            int  p = (int)Math.Round((amount - r) * 100);
            string w = ToWords(r) + " Rupees";
            if (p > 0) w += " and " + ToWords(p) + " Paise";
            return w + " only";
        }
        catch { return ""; }
    }

    private static string ToWords(long n)
    {
        if (n == 0) return "Zero";
        if (n < 0)  return "Minus " + ToWords(-n);
        string[] ones = { "", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight",
            "Nine", "Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen",
            "Sixteen", "Seventeen", "Eighteen", "Nineteen" };
        string[] tens = { "", "", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety" };
        string w = "";
        if (n >= 10000000) { w += ToWords(n / 10000000) + " Crore ";   n %= 10000000; }
        if (n >= 100000)   { w += ToWords(n / 100000)   + " Lakh ";    n %= 100000;   }
        if (n >= 1000)     { w += ToWords(n / 1000)     + " Thousand "; n %= 1000;    }
        if (n >= 100)      { w += ones[n / 100] + " Hundred "; n %= 100; }
        if (n >= 20)       { w += tens[n / 10]; n %= 10; if (n > 0) w += "-" + ones[n]; }
        else if (n > 0)    { w += ones[n]; }
        return w.Trim();
    }

protected static string BuildLogoHtml(string logoPath, int maxH, int maxW)
    {
        if (string.IsNullOrEmpty(logoPath) || !File.Exists(logoPath)) return "";
        try
        {
            string ext  = Path.GetExtension(logoPath).ToLower().TrimStart('.');
            string mime = ext is "jpg" or "jpeg" ? "image/jpeg" : "image/png";
            string b64 = Convert.ToBase64String(File.ReadAllBytes(logoPath));
            return $"<img src=\"data:{mime};base64,{b64}\" style=\"max-height:{maxH}px;max-width:{maxW}px;object-fit:contain;display:block\" alt=\"\"/>";
        }
        catch { return ""; }
    }

    protected static string BuildQRHtml(string qrPath, int size)
    {
        if (string.IsNullOrEmpty(qrPath) || !File.Exists(qrPath)) return "";
        try
        {
            string ext  = Path.GetExtension(qrPath).ToLower().TrimStart('.');
            string mime = ext is "jpg" or "jpeg" ? "image/jpeg" : "image/png";
            string b64  = Convert.ToBase64String(File.ReadAllBytes(qrPath));
            return $"<img src=\"data:{mime};base64,{b64}\" style=\"width:{size}px;height:{size}px;object-fit:contain;display:block\" alt=\"QR\"/>";
        }
        catch { return ""; }
    }



    // ══════════════════════════════════════════════════════════════════════════
    //  QUEST PDF GENERATION
    // ══════════════════════════════════════════════════════════════════════════
    // ══════════════════════════════════════════════════════════════════════════
    //  QUEST PDF GENERATION (BALANCED & CLEAN LAYOUT)
    // ══════════════════════════════════════════════════════════════════════════

    protected void ComposePdfContent(IContainer container, ErpDocument doc)
    {
        container.PaddingTop(6).Column(col =>
        {
            col.Item().Element(c => ComposePdfItemsTable(c, doc));
            col.Item().Element(c => ComposePdfTotalsAndTerms(c, doc));
            if (ShowBankSection)
                col.Item().Element(c => ComposePdfBankSection(c, doc));
            col.Item().Element(c => ComposePdfSignatory(c, doc));
        });
    }

    protected void ComposePdfHeader(IContainer container, ErpDocument doc)
    {
        container.Column(col =>
        {
            // Letterhead
            col.Item().PaddingBottom(8).Row(row =>
            {
                row.RelativeItem().Column(c =>
                {
                    c.Item().Text(doc.Company.Name).FontSize(18).Bold();
                    c.Item().Text(doc.Company.Address).FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Company.Email))
                        c.Item().Text($"Email: {doc.Company.Email}").FontSize(10);
                    c.Item().Text($"GSTIN: {doc.Company.GSTIN}").FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Company.StateCode))
                        c.Item().Text($"State: {doc.Company.StateCode}").FontSize(10);
                    if (!string.IsNullOrEmpty(doc.Company.Phone))
                        c.Item().Text($"Ph: {doc.Company.Phone}").FontSize(10);
                });

                // FIX: Load Logo via byte array for 100% reliability
                if (!string.IsNullOrEmpty(doc.Company.LogoPath) && File.Exists(doc.Company.LogoPath))
                {
                    try {
                        byte[] logoBytes = File.ReadAllBytes(doc.Company.LogoPath);
                        row.ConstantItem(150).AlignRight().Height(55).Image(logoBytes).FitArea();
                    } catch { /* Ignore if file locked */ }
                }
            });

            // Title Bar - Clean, simple borders
            col.Item().BorderTop(1).BorderBottom(1).BorderColor(Colors.Black)
               .PaddingVertical(4).AlignCenter().Text(DocLabel(doc.DocType)).FontSize(12).Bold();

            // 3-Column Header Grid
            col.Item().PaddingVertical(8).Row(row =>
            {
                // Bill To
                row.RelativeItem().PaddingRight(10).Column(c =>
                {
                    c.Item().Text(BillToLabel.ToUpper()).FontSize(8).Bold().FontColor(Colors.Grey.Medium);
                    c.Item().Text(doc.Customer.Name).FontSize(11).Bold();
                    c.Item().Text(doc.Customer.BillingAddress).FontSize(10);
                    
                    // FIX: Simple GSTIN format, no border/colors
                    if (!string.IsNullOrEmpty(doc.Customer.GSTIN))
                        c.Item().Text($"GSTIN: {doc.Customer.GSTIN}").FontSize(10);
                        
                    if (!string.IsNullOrEmpty(doc.Customer.StateCode))
                        c.Item().Text($"State: {doc.Customer.StateCode}").FontSize(10);
                });

                // Ship To
                row.RelativeItem().BorderLeft(1).BorderColor(Colors.Grey.Lighten2).PaddingLeft(10).PaddingRight(10).Column(c =>
                {
                    c.Item().Text(ShipToLabel.ToUpper()).FontSize(8).Bold().FontColor(Colors.Grey.Medium);
                    string shipAddr = string.IsNullOrWhiteSpace(doc.Customer.ShippingAddress) ? doc.Customer.BillingAddress : doc.Customer.ShippingAddress;
                    c.Item().Text(shipAddr).FontSize(10);
                });

                // Details
                row.RelativeItem().BorderLeft(1).BorderColor(Colors.Grey.Lighten2).PaddingLeft(10).Column(c =>
                {
                    c.Item().PaddingBottom(4).Text("INVOICE DETAILS").FontSize(8).Bold().FontColor(Colors.Grey.Medium);
                    
                    void AddRow(string lbl, string val) {
                        c.Item().Row(r => {
                            r.RelativeItem().Text(lbl).FontSize(10);
                            r.RelativeItem().AlignRight().Text(val).FontSize(10).Bold();
                        });
                    }

                    AddRow(DocumentNoLabel, CleanDocNo(doc.DocumentNo));
                    AddRow("Date:", doc.Date.ToString("dd-MM-yyyy"));
                    if (!string.IsNullOrEmpty(doc.PlaceOfSupply)) AddRow("Place of supply:", doc.PlaceOfSupply);
                    if (!string.IsNullOrEmpty(doc.CustomerRefNo)) AddRow("PO Ref No:", doc.CustomerRefNo);
                    if (ShowEWayBill && !string.IsNullOrEmpty(doc.EWayBillNo)) AddRow("E-Way Bill No:", doc.EWayBillNo);
                    if (!string.IsNullOrEmpty(doc.CreatedBy)) AddRow("Prepared by:", doc.CreatedBy);
                });
            });
            col.Item().LineHorizontal(1).LineColor(Colors.Black);
        });
    }

    private void ComposePdfItemsTable(IContainer container, ErpDocument doc)
    {
        container.Table(table =>
        {
            table.ColumnsDefinition(columns =>
            {
                columns.ConstantColumn(25);   // #
                columns.RelativeColumn();     // Description
                columns.ConstantColumn(60);   // HSN
                columns.ConstantColumn(45);   // Qty
                columns.ConstantColumn(35);   // Unit
                columns.ConstantColumn(65);   // Rate
                columns.ConstantColumn(55);   // GST
                columns.ConstantColumn(80);   // Amount
            });

            // Clean headers
            table.Header(header =>
            {
                void HeadCell(QuestPDF.Infrastructure.IContainer c, string text, bool right = false)
                {
                    var cell = c.BorderBottom(1).BorderColor(Colors.Black).PaddingVertical(4).PaddingHorizontal(3);
                    if (right) cell.AlignRight().Text(text).FontSize(9).Bold();
                    else cell.Text(text).FontSize(9).Bold();
                }

                HeadCell(header.Cell(), "#");
                HeadCell(header.Cell(), "Item Name");
                HeadCell(header.Cell(), "HSN/SAC");
                HeadCell(header.Cell(), "Qty", true);
                HeadCell(header.Cell(), "Unit", true);
                HeadCell(header.Cell(), "Rate", true);
                HeadCell(header.Cell(), "GST", true);
                HeadCell(header.Cell(), "Amount", true);
            });

            // Moderate padding (4) for a clean but space-saving look
            foreach (var item in doc.Items)
            {
                decimal gstAmt = item.LineTotal * item.GSTPercent / 100;

                void BodyCell(QuestPDF.Infrastructure.IContainer c, string text, int size, bool bold = false, bool right = false, string color = "#000000")
                {
                    var cell = c.BorderBottom(1).BorderColor(Colors.Grey.Lighten3).PaddingVertical(4).PaddingHorizontal(3);
                    var txt = right ? cell.AlignRight().Text(text) : cell.Text(text);
                    txt.FontSize(size).FontColor(color);
                    if (bold) txt.Bold();
                }

                BodyCell(table.Cell(), item.ItemNumber.ToString(), 9);
                BodyCell(table.Cell(), item.Description, 10, true);
                BodyCell(table.Cell(), item.HSN, 9);
                BodyCell(table.Cell(), item.Quantity.ToString("N2"), 10, false, true);
                BodyCell(table.Cell(), item.UOM, 9, false, true);
                BodyCell(table.Cell(), $"₹{item.Rate:N2}", 10, false, true);
                BodyCell(table.Cell(), $"₹{gstAmt:N2}", 8, false, true, Colors.Grey.Darken2);
                BodyCell(table.Cell(), $"₹{item.LineTotal:N2}", 10, true, true);
            }

            // Table Footer
            decimal sub = doc.Items.Sum(i => i.LineTotal);
            decimal totalGst = doc.Items.Sum(i => i.LineTotal * i.GSTPercent / 100);

            table.Cell().ColumnSpan(3).PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text("Total").FontSize(10).Bold();
            table.Cell().PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text(doc.Items.Sum(i => i.Quantity).ToString("N2")).FontSize(10).Bold();
            table.Cell().ColumnSpan(2).PaddingVertical(4).PaddingHorizontal(3);
            table.Cell().PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text($"₹{totalGst:N2}").FontSize(9).Bold();
            table.Cell().PaddingVertical(4).PaddingHorizontal(3).AlignRight().Text($"₹{sub:N2}").FontSize(10).Bold();
        });
    }

    private void ComposePdfTotalsAndTerms(IContainer container, ErpDocument doc)
    {
        decimal sub = doc.Items.Sum(i => i.LineTotal);
        decimal taxable = sub - doc.Discount;
        decimal tax = taxable * doc.GstPercent / 100;
        decimal grand = taxable + tax + doc.Freight;
        bool isCgst = doc.GstMode == GstMode.CgstSgst;

        container.BorderBottom(1).BorderColor(Colors.Black).Row(row =>
        {
            // Left: Terms & Amount in Words
            row.RelativeItem().Padding(10).BorderRight(1).BorderColor(Colors.Grey.Lighten2).Column(c =>
            {
                c.Item().Text("AMOUNT IN WORDS").FontSize(8).Bold();
                c.Item().PaddingBottom(8).Text(AmountInWords(grand)).FontSize(10).Italic();

                if (!string.IsNullOrWhiteSpace(doc.GeneralTerms) || !string.IsNullOrWhiteSpace(doc.PaymentTerms))
                {
                    c.Item().PaddingTop(8).BorderTop(1).BorderColor(Colors.Grey.Lighten3).PaddingTop(4)
                     .Text("TERMS & CONDITIONS").FontSize(8).Bold();

                    int lineNo = 1;
                    if (!string.IsNullOrWhiteSpace(doc.GeneralTerms))
                        foreach (var line in doc.GeneralTerms.Split('\n'))
                            if (!string.IsNullOrWhiteSpace(line))
                                c.Item().Text($"{lineNo++}. {line.Trim()}").FontSize(9);

                    if (!string.IsNullOrWhiteSpace(doc.PaymentTerms))
                        c.Item().Text($"{lineNo}. {doc.PaymentTerms}").FontSize(9);
                }
            });

            // Right: Totals
            row.ConstantItem(220).Padding(10).Column(c =>
            {
                void AddTot(string lbl, string val, bool isGrand = false) 
                {
                    c.Item().PaddingBottom(4).Row(r => 
                    {
                        var txtLbl = r.RelativeItem().Text(lbl).FontSize(isGrand ? 11 : 10);
                        if (isGrand) txtLbl.Bold();
                        
                        var txtVal = r.RelativeItem().AlignRight().Text(val).FontSize(isGrand ? 13 : 10);
                        if (isGrand) txtVal.Bold();
                    });
                }

                AddTot("Sub Total", $"₹{sub:N2}");
                if (doc.Discount > 0) AddTot("Discount", $"-₹{doc.Discount:N2}");
                
                if (isCgst) {
                    AddTot($"CGST @ {doc.GstPercent / 2:N1}%", $"₹{tax / 2:N2}");
                    AddTot($"SGST @ {doc.GstPercent / 2:N1}%", $"₹{tax / 2:N2}");
                } else {
                    AddTot($"IGST @ {doc.GstPercent:N0}%", $"₹{tax:N2}");
                }
                
                if (doc.Freight > 0) AddTot("Freight", $"₹{doc.Freight:N2}");

                c.Item().PaddingVertical(4).LineHorizontal(1).LineColor(Colors.Black);
                AddTot(TotalsLabel, $"₹{grand:N2}", true);

                if (doc.PendingAmount < grand)
                {
                    decimal received = grand - doc.PendingAmount;
                    AddTot("Received", $"₹{received:N2}");
                    AddTot("Balance", $"₹{doc.PendingAmount:N2}");
                }
            });
        });
    }

    private void ComposePdfBankSection(IContainer container, ErpDocument doc)
    {
        bool hasBank = !string.IsNullOrWhiteSpace(doc.Company.Bank);
        bool hasQr = !string.IsNullOrEmpty(doc.Company.QRCodePath) && File.Exists(doc.Company.QRCodePath);

        if (!hasBank && !hasQr) return;

        // Restored Bank details to vertical list & QR size
        container.Padding(12).BorderBottom(1).BorderColor(Colors.Grey.Lighten2).Row(row =>
        {
            if (hasQr)
            {
                try {
                    byte[] qrBytes = File.ReadAllBytes(doc.Company.QRCodePath);
                    row.ConstantItem(65).Height(65).Image(qrBytes).FitArea();
                } catch { /* Ignore locked file */ }
            }

            if (hasBank)
                row.RelativeItem().PaddingLeft(hasQr ? 15 : 0).Column(c =>
                {
                    c.Item().Text("PAY TO :").FontSize(8).Bold().FontColor(Colors.Grey.Medium);
                    c.Item().Text($"Bank Name: {doc.Company.Bank}").FontSize(10);
                    c.Item().Text($"Account No: {doc.Company.Account}").FontSize(10);
                    c.Item().Text($"IFSC Code: {doc.Company.IFSC}").FontSize(10);
                    c.Item().Text($"Account Holder: {doc.Company.Name}").FontSize(10);
                });
        });
    }

    private void ComposePdfSignatory(IContainer container, ErpDocument doc)
    {
        container.Padding(15).Row(row =>
        {
            row.RelativeItem(); // Spacer
            row.ConstantItem(180).AlignRight().Column(c =>
            {
                c.Item().Height(50).Border(1).BorderColor(Colors.Grey.Lighten2).AlignCenter().AlignMiddle()
                 .Text("Stamp / Seal").FontSize(9).FontColor(Colors.Grey.Lighten1);
                c.Item().PaddingTop(4).BorderTop(1).BorderColor(Colors.Black).PaddingTop(2)
                 .Text($"For: {doc.Company.Name}").FontSize(10).Bold();
                c.Item().Text(doc.Company.Signatory).FontSize(9);
            });
        });
    }

    // ══════════════════════════════════════════════════════════════════════════
    //  HTML GENERATION (Legacy but Refactored to use Shared Properties)
    // ══════════════════════════════════════════════════════════════════════════

    public virtual string BuildHtml(ErpDocument doc)
    {
        decimal sub     = doc.Items.Sum(i => i.LineTotal);
        decimal taxable = sub - doc.Discount;
        decimal tax     = taxable * doc.GstPercent / 100;
        decimal grand   = taxable + tax + doc.Freight;

        string logo        = BuildLogoHtml(doc.Company.LogoPath, InvoiceSettings.LogoHeight, InvoiceSettings.LogoWidth);
        string stripe      = BuildStripe();
        string letterhead  = BuildLetterhead(doc, logo);
        string titleBar    = BuildTitleBar(doc);
        string headerGrid  = BuildHeaderGrid(doc);
        string itemsTable  = BuildItemsTable(doc);
        string totalsBlock = BuildTotalsBlock(doc);
        string bankSection = ShowBankSection ? BuildBankSection(doc) : "";
        string wordsTerms  = BuildTermsAndWords(doc, grand);
        string signatory   = BuildSignatory(doc);
        string css         = BuildPageCss();
        string dLabel      = DocLabel(doc.DocType);

        return $@"<!DOCTYPE html>
<html lang='en'>
<head>
<meta charset='UTF-8'>
<title>{dLabel} — {H(CleanDocNo(doc.DocumentNo))}</title>
{css}
</head>
<body>
<div class='page'>
{stripe}{letterhead}{titleBar}{headerGrid}{itemsTable}
<div style='display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid #DDD'>
  <div style='padding:14px 16px;border-right:1px solid #DDD'>{wordsTerms}</div>
  <div style='padding:14px 16px'>{totalsBlock}</div>
</div>
{bankSection}{signatory}
<div style='background:#F8F8F8;border-top:2px solid {CTD};padding:7px 26px;display:flex;justify-content:space-between;font-size:10px;color:#888'>
  <span>Generated: {DateTime.Now:dd MMM yyyy, HH:mm}</span>
  <span style='font-weight:600;color:{CA}'>{dLabel} · {H(CleanDocNo(doc.DocumentNo))}</span>
  <span>Thank you for your business</span>
</div>
</div>
</body>
</html>";
    }

    protected virtual string BuildStripe() =>
        $"<div style='height:{InvoiceSettings.StripeHeight}px;background:{InvoiceSettings.StripeGradient};print-color-adjust:exact;-webkit-print-color-adjust:exact'></div>";

    protected virtual string BuildLetterhead(ErpDocument doc, string logoHtml)
    {
        return $"<div style='display:flex;align-items:flex-start;justify-content:space-between;padding:20px 26px 14px'>" +
               $"<div style='flex:1'>" +
               $"<div style='font-size:18px;font-weight:800;color:{CTD};margin-bottom:3px'>{H(doc.Company.Name)}</div>" +
               $"<div style='font-size:{FsS}px;color:#444;line-height:1.7'>{H(doc.Company.Address)}</div>" +
               $"<div style='font-size:{FsS}px;color:#444'>GSTIN : {H(doc.Company.GSTIN)}</div>" +
               $"<div style='font-size:{FsS}px;color:#444'>State : {H(doc.Company.StateCode)}</div>" +
               $"<div style='font-size:{FsS}px;color:#444'>Ph : {H(doc.Company.Phone)}</div>" +
               $"</div><div style='flex-shrink:0;margin-left:20px'>{logoHtml}</div></div>";
    }

    protected virtual string BuildTitleBar(ErpDocument doc) =>
        $"<div style='text-align:center;padding:8px 26px;border-top:1px solid #DDD;border-bottom:1px solid #DDD;background:#FAFAFA'>" +
        $"<span style='font-size:17px;font-weight:700;color:{CTD}'>{DocLabel(doc.DocType)}</span></div>";

    protected virtual string BuildHeaderGrid(ErpDocument doc)
    {
        var sb = new StringBuilder();
        sb.Append("<div style='display:grid;grid-template-columns:1fr 1fr 1fr;border-bottom:1px solid #DDD'>");

        // Bill To
        sb.Append($"<div style='padding:12px 16px;border-right:1px solid #DDD'>");
        sb.Append($"<div style='font-size:{FsM}px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px'>{BillToLabel}</div>");
        sb.Append($"<div style='font-size:13px;font-weight:700;color:{CTD};margin-bottom:2px'>{H(doc.Customer.Name)}</div>");
        sb.Append($"<div style='font-size:{FsS}px;color:#444;line-height:1.65'>{H(doc.Customer.BillingAddress).Replace("\n","<br/>")}</div>");
        if (!string.IsNullOrWhiteSpace(doc.Customer.GSTIN))
            sb.Append($"<div style='font-size:10px;color:{CA};font-family:monospace;border:1px solid {CBR};padding:1px 7px;border-radius:3px;display:inline-block;margin-top:3px'>GSTIN : {H(doc.Customer.GSTIN)}</div>");
        sb.Append("</div>");

        // Ship To
        string shipAddr = string.IsNullOrWhiteSpace(doc.Customer.ShippingAddress) ? doc.Customer.BillingAddress : doc.Customer.ShippingAddress;
        sb.Append($"<div style='padding:12px 16px;border-right:1px solid #DDD'>");
        sb.Append($"<div style='font-size:{FsM}px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px'>{ShipToLabel}</div>");
        sb.Append($"<div style='font-size:{FsS}px;color:#444;line-height:1.65'>{H(shipAddr).Replace("\n","<br/>")}</div>");
        sb.Append("</div>");

        // Details
        sb.Append($"<div style='padding:12px 16px'>");
        sb.Append($"<div style='font-size:{FsM}px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px'>Details</div>");
        sb.Append(DetRow(DocumentNoLabel, H(CleanDocNo(doc.DocumentNo))));
        sb.Append(DetRow("Date :", doc.Date.ToString("dd-MM-yyyy")));
        if (!string.IsNullOrWhiteSpace(doc.PlaceOfSupply)) sb.Append(DetRow("Place of supply:", H(doc.PlaceOfSupply)));
        if (!string.IsNullOrWhiteSpace(doc.CustomerRefNo)) sb.Append(DetRow("PO Ref No:", H(doc.CustomerRefNo)));
        if (ShowEWayBill && !string.IsNullOrWhiteSpace(doc.EWayBillNo)) sb.Append(DetRow("E-Way Bill No:", H(doc.EWayBillNo)));
        sb.Append("</div></div>");
        return sb.ToString();
    }

    protected string DetRow(string lbl, string val) =>
        $"<div style='display:flex;justify-content:space-between;font-size:{FsS}px;padding:3px 0;border-bottom:1px dotted #EEE'>" +
        $"<span style='color:#666;font-weight:500'>{lbl}</span><span style='font-weight:600;color:{CTD};text-align:right'>{val}</span></div>";

    protected string TotRow(string lbl, string val, bool highlight) =>
        $"<div style='display:flex;justify-content:space-between;font-size:{FsS}px;padding:4px 0;border-bottom:1px dotted #EEE'>" +
        $"<span style='color:{(highlight ? "#059669" : "#555")}'>{lbl}</span>" +
        $"<span style='font-weight:600;color:{(highlight ? "#059669" : CTD)};font-family:monospace'>{val}</span></div>";

    protected virtual string BuildItemsTable(ErpDocument doc)
    {
        var sb = new StringBuilder();
        sb.Append("<div style='border-bottom:1px solid #DDD'><table style='width:100%;border-collapse:collapse'>");
        sb.Append($"<thead><tr style='background:linear-gradient(90deg,{CTH1},{CTH2});print-color-adjust:exact;-webkit-print-color-adjust:exact'>");
        sb.Append("<th style='padding:9px;text-align:left'>#</th><th style='padding:9px;text-align:left'>Description</th><th style='padding:9px;text-align:right'>Qty</th><th style='padding:9px;text-align:right'>Rate</th><th style='padding:9px;text-align:right'>Amount</th>");
        sb.Append("</tr></thead><tbody>");
        foreach (var item in doc.Items)
        {
            sb.Append($"<tr style='background:{(item.ItemNumber % 2 == 0 ? "#FAFAFA" : "#FFF")};border-bottom:1px solid #F0F0F0'>");
            sb.Append($"<td style='padding:7px'>{item.ItemNumber}</td><td>{H(item.Description)}</td><td style='text-align:right'>{item.Quantity:N2}</td><td style='text-align:right'>₹{item.Rate:N2}</td><td style='text-align:right;font-weight:bold'>₹{item.LineTotal:N2}</td>");
            sb.Append("</tr>");
        }
        sb.Append("</tbody></table></div>");
        return sb.ToString();
    }

    protected virtual string BuildTotalsBlock(ErpDocument doc)
    {
        decimal sub = doc.Items.Sum(i => i.LineTotal);
        decimal taxable = sub - doc.Discount;
        decimal tax = taxable * doc.GstPercent / 100;
        decimal grand = taxable + tax + doc.Freight;

        var sb = new StringBuilder();
        sb.Append(TotRow("Sub Total", $"₹{sub:N2}", false));
        if (doc.Discount > 0) sb.Append(TotRow("Discount", $"−₹{doc.Discount:N2}", true));
        sb.Append(TotRow("GST", $"₹{tax:N2}", false));
        if (doc.Freight > 0) sb.Append(TotRow("Freight", $"₹{doc.Freight:N2}", false));

        sb.Append($"<div style='display:flex;justify-content:space-between;font-size:14px;font-weight:700;padding:7px 0;border-top:2px solid {CTD};margin-top:2px'>" +
                  $"<span>{TotalsLabel}</span><span>₹{grand:N2}</span></div>");
        return sb.ToString();
    }

    protected virtual string BuildBankSection(ErpDocument doc) => "";
    protected virtual string BuildTermsAndWords(ErpDocument doc, decimal grand) => 
        $"<div style='font-size:{FsM}px;font-weight:700'>{AmountInWords(grand)}</div><div style='font-size:{FsS}px;margin-top:10px'>{H(doc.PaymentTerms)}</div>";
    protected virtual string BuildSignatory(ErpDocument doc) => "";
    protected virtual string BuildPageCss() => "<style>body{font-family:Arial,sans-serif;font-size:13px}</style>";
}
```


