<UserControl x:Class="Ojaswat.Pages.MasterDataPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,20,20,20">

            <!-- Customer Master -->
            <Border Background="#FFFFFF" CornerRadius="12" Padding="22,18"
                    BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="👥  Customer Master" Foreground="#0F172A"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="✚  New"        Background="#3B82F6" Foreground="White" Style="{StaticResource Btn}" Click="NewCustomer_Click"/>
                        <Button Content="⬆  Import CSV" Background="#F1F5F9" Foreground="#475569" Style="{StaticResource Btn}" Click="ImportCustomers_Click"/>
                        <Button Content="⬇  Export CSV" Background="#10B981" Foreground="White"  Style="{StaticResource Btn}" Click="ExportCustomers_Click"/>
                        <Button Content="🗑  Clear All" Background="#EF4444" Foreground="White"  Style="{StaticResource Btn}" Click="ClearCustomers_Click"/>
                        <Button Content="⟳"             Background="#F1F5F9" Foreground="#475569" Style="{StaticResource Btn}" Width="32" Click="RefreshCustomers_Click"/>
                        <TextBlock x:Name="CustomerStatus" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid x:Name="CustomerGrid" MaxHeight="220" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True"
                              MouseDoubleClick="CustomerGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"            Binding="{Binding Name}"           Width="*"/>
                            <DataGridTextColumn Header="GSTIN"           Binding="{Binding GSTIN}"          Width="155"/>
                            <DataGridTextColumn Header="State Code"      Binding="{Binding StateCode}"      Width="100"/>
                            <DataGridTextColumn Header="Billing Address" Binding="{Binding BillingAddress}" Width="220"/>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand" Width="28" Click="CustomerEdit_Click"/>
                                            <Button Content="🗑" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand" Width="28" Click="CustomerDelete_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Item Master -->
            <Border Background="#FFFFFF" CornerRadius="12" Padding="22,18"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="📦  Item Master" Foreground="#0F172A"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="✚  New"        Background="#3B82F6" Foreground="White" Style="{StaticResource Btn}" Click="NewItem_Click"/>
                        <Button Content="⬆  Import CSV" Background="#F1F5F9" Foreground="#475569" Style="{StaticResource Btn}" Click="ImportItems_Click"/>
                        <Button Content="⬇  Export CSV" Background="#10B981" Foreground="White"  Style="{StaticResource Btn}" Click="ExportItems_Click"/>
                        <Button Content="🗑  Clear All" Background="#EF4444" Foreground="White"  Style="{StaticResource Btn}" Click="ClearItems_Click"/>
                        <Button Content="⟳"             Background="#F1F5F9" Foreground="#475569" Style="{StaticResource Btn}" Width="32" Click="RefreshItems_Click"/>
                        <TextBlock x:Name="ItemStatus" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid x:Name="ItemGrid" MaxHeight="220" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True"
                              MouseDoubleClick="ItemGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item Name"    Binding="{Binding Name}"        Width="*"/>
                            <DataGridTextColumn Header="HSN/SAC"     Binding="{Binding HSN}"         Width="100"/>
                            <DataGridTextColumn Header="Unit"         Binding="{Binding UOM}"         Width="70"/>
                            <DataGridTextColumn Header="Default Rate" Binding="{Binding DefaultRate, StringFormat='₹{0:N2}'}" Width="120"/>
                            <DataGridTextColumn Header="GST %"       Binding="{Binding GSTPercent}"  Width="70"/>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand" Width="28" Click="ItemEdit_Click"/>
                                            <Button Content="🗑" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand" Width="28" Click="ItemDelete_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

