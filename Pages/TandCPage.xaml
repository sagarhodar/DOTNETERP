<UserControl x:Class="Ojaswat.Pages.TandCPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,10"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="✚  New T&amp;C"   Click="New_Click"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Height="34" Padding="14,0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,6,0"/>
                <Button Content="⬆  Import CSV" Click="Import_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Height="34" Padding="14,0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,6,0"/>
                <Button Content="⬇  Export CSV" Click="Export_Click"
                        Background="#10B981" Foreground="White" BorderThickness="0"
                        Height="34" Padding="14,0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,6,0"/>
                <Button Content="⟳"             Click="Refresh_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Height="34" Width="34" Cursor="Hand"/>
                <TextBlock x:Name="StatusText" Foreground="#64748B" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="14,10,14,14" Background="#FFFFFF"
                CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="TandCGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True"
                      MouseDoubleClick="Grid_DoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Label"         Binding="{Binding Label}"        Width="160"/>
                    <DataGridTextColumn Header="Doc Type"      Binding="{Binding DocType}"      Width="140"/>
                    <DataGridTextColumn Header="Payment Terms" Binding="{Binding PaymentTerms}" Width="*"/>
                    <DataGridTextColumn Header="General Terms" Binding="{Binding GeneralTerms}" Width="*"/>
                    <DataGridTemplateColumn Header="" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand" Width="28" Click="Edit_Click"/>
                                    <Button Content="🗑" Tag="{Binding}" Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand" Width="28" Click="Delete_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
