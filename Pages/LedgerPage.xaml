<UserControl x:Class="Ojaswat.Pages.LedgerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,12"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="⟳  Refresh"    Click="Refresh_Click"
                            Style="{StaticResource BtnGhost}" Padding="14,0" Height="34" Margin="0,0,8,0"/>
                    <Button Content="⬇  Export CSV"  Click="ExportCsv_Click"
                            Style="{StaticResource BtnGreen}" Padding="14,0" Height="34" Margin="0,0,16,0"/>

                    <!-- Party type filter -->
                    <ComboBox x:Name="PartyTypeCombo" Width="140" Height="34" Margin="0,0,8,0">
                        <ComboBoxItem Content="All Parties" IsSelected="True"/>
                        <ComboBoxItem Content="Customer"/>
                        <ComboBoxItem Content="Vendor"/>
                    </ComboBox>

                    <!-- Party name filter -->
                    <TextBlock Text="Party:" Foreground="#64748B" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PartyFilterCombo" Width="240" Height="34"/>
                    <Button Content="✕" Click="ClearPartyFilter_Click"
                            Background="Transparent" Foreground="#94A3B8"
                            BorderThickness="0" Cursor="Hand" Width="28" Height="34"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="StatusText"
                           Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18,14,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab bar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="TabSummary" Content="  👥  Party Summary"
                             IsChecked="True" Checked="Tab_Changed"
                             Style="{StaticResource NavRadioBtn}"
                             GroupName="LedTab"
                             Background="#FFFFFF" Foreground="#0F172A"
                             BorderBrush="#E2E8F0" BorderThickness="1"
                             Padding="14,8" Height="36" FontSize="12" Cursor="Hand"/>
                <RadioButton x:Name="TabDetail" Content="  📒  Ledger Detail (All entries)"
                             Checked="Tab_Changed"
                             Style="{StaticResource NavRadioBtn}"
                             GroupName="LedTab"
                             Background="#FFFFFF" Foreground="#0F172A"
                             BorderBrush="#E2E8F0" BorderThickness="1"
                             Padding="14,8" Height="36" FontSize="12" Cursor="Hand"
                             Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Party Summary grid -->
            <Border x:Name="SummaryPanel" Grid.Row="1"
                    Background="#FFFFFF" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
                <DataGrid x:Name="SummaryGrid" IsReadOnly="True"
                          MouseDoubleClick="SummaryGrid_DoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Party Name"    Binding="{Binding PartyName}"    Width="*"/>
                        <DataGridTextColumn Header="Type"          Binding="{Binding PartyType}"    Width="90"/>
                        <DataGridTextColumn Header="Total Debit"   Binding="{Binding TotalDebit,  StringFormat='₹{0:N2}'}" Width="120"/>
                        <DataGridTextColumn Header="Total Credit"  Binding="{Binding TotalCredit, StringFormat='₹{0:N2}'}" Width="120"/>
                        <DataGridTextColumn Header="Balance"       Binding="{Binding BalanceLabel}"                        Width="110"/>
                        <DataGridTemplateColumn Header="Dr / Cr" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BalanceColor}" CornerRadius="4"
                                            Padding="6,2" HorizontalAlignment="Center" Margin="0,5">
                                        <TextBlock Text="{Binding BalanceType}"
                                                   Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Ledger Detail grid -->
            <Border x:Name="DetailPanel" Grid.Row="1" Visibility="Collapsed"
                    Background="#FFFFFF" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
                <DataGrid x:Name="DetailGrid" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"       Binding="{Binding DateLabel}"      Width="100"/>
                        <DataGridTextColumn Header="Party"      Binding="{Binding PartyName}"      Width="160"/>
                        <DataGridTextColumn Header="Type"       Binding="{Binding PartyType}"      Width="80"/>
                        <DataGridTextColumn Header="Entry"      Binding="{Binding EntryTypeLabel}" Width="110"/>
                        <DataGridTextColumn Header="Debit"      Binding="{Binding DebitLabel}"     Width="110"/>
                        <DataGridTextColumn Header="Credit"     Binding="{Binding CreditLabel}"    Width="110"/>
                        <DataGridTextColumn Header="Balance"    Binding="{Binding BalanceLabel}"   Width="110"/>
                        <DataGridTextColumn Header="Document"   Binding="{Binding DocumentNo}"     Width="130"/>
                        <DataGridTextColumn Header="Doc Type"   Binding="{Binding DocType}"        Width="110"/>
                        <DataGridTextColumn Header="Narration"  Binding="{Binding Narration}"      Width="*"/>
                        <DataGridTemplateColumn Header="Delete" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="❌"
                                            Tag="{Binding Id}"
                                            Click="DeleteLedger_Click"
                                            Width="30" Height="25"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
