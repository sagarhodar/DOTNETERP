<UserControl x:Class="Ojaswat.Pages.ReportItemsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,12"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="⟳  Refresh" Click="Refresh_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Height="34" Padding="14,0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="⬇  Export CSV" Click="ExportCsv_Click"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Height="34" Padding="14,0" FontWeight="SemiBold" Cursor="Hand"/>
                <TextBlock x:Name="StatusText" Foreground="#64748B" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="18,14,18,18" Background="#FFFFFF"
                CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="ItemReportGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Document No"  Binding="{Binding DocumentNo}"   Width="135"/>
                    <DataGridTextColumn Header="Type"         Binding="{Binding DocTypeLabel}" Width="120"/>
                    <DataGridTextColumn Header="Party"        Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="Date"         Binding="{Binding DateLabel}"    Width="100"/>
                    <DataGridTextColumn Header="Item"         Binding="{Binding ItemDesc}"     Width="*"/>
                    <DataGridTextColumn Header="HSN"          Binding="{Binding HSN}"          Width="80"/>
                    <DataGridTextColumn Header="Qty"          Binding="{Binding Qty, StringFormat='{}{0:N2}'}"  Width="70"/>
                    <DataGridTextColumn Header="Rate"         Binding="{Binding Rate, StringFormat='₹{0:N2}'}"  Width="90"/>
                    <DataGridTextColumn Header="Amount"       Binding="{Binding Amount, StringFormat='₹{0:N2}'}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
