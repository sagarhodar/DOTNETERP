<UserControl x:Class="Ojaswat.Pages.GstReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,12"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="⟳  Refresh" Click="Refresh_Click"
                        Background="#F1F5F9" Foreground="#475569" BorderThickness="0"
                        Height="34" Padding="14,0" Margin="0,0,10,0" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Content="⬇  Export CSV" Click="ExportCsv_Click"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        Height="34" Padding="14,0" FontWeight="SemiBold" Cursor="Hand"/>
                <TextBlock x:Name="StatusText" Foreground="#64748B" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Margin="18,14,18,18" Background="#FFFFFF"
                CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="GstGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Month"       Binding="{Binding MonthYear}"  Width="90"/>
                    <DataGridTextColumn Header="Doc Type"    Binding="{Binding DocType}"    Width="140"/>
                    <DataGridTextColumn Header="Count"       Binding="{Binding Count}"      Width="60"/>
                    <DataGridTextColumn Header="Taxable (₹)" Binding="{Binding Taxable, StringFormat='₹{0:N2}'}"    Width="120"/>
                    <DataGridTextColumn Header="CGST (₹)"   Binding="{Binding CGST, StringFormat='₹{0:N2}'}"       Width="110"/>
                    <DataGridTextColumn Header="SGST (₹)"   Binding="{Binding SGST, StringFormat='₹{0:N2}'}"       Width="110"/>
                    <DataGridTextColumn Header="IGST (₹)"   Binding="{Binding IGST, StringFormat='₹{0:N2}'}"       Width="110"/>
                    <DataGridTextColumn Header="Total Tax"   Binding="{Binding TotalTax, StringFormat='₹{0:N2}'}"   Width="110"/>
                    <DataGridTextColumn Header="Grand Total" Binding="{Binding GrandTotal, StringFormat='₹{0:N2}'}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
